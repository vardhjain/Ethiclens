# Copy to .env and adjust. Never commit real secrets.

# --- API ---
ETHICLENS_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (PostgreSQL) ---
POSTGRES_USER=ethiclens
POSTGRES_PASSWORD=ethiclens
POSTGRES_DB=ethiclens
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async driver for the app; Alembic uses a sync driver derived from this.
DATABASE_URL=postgresql+asyncpg://ethiclens:ethiclens@localhost:5432/ethiclens

# --- Redis / task queue ---
REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Model ingestion limits ---
MAX_MODEL_UPLOAD_MB=512
INGESTION_SANDBOX_TIMEOUT_SECONDS=60

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
